generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  password        String?
  accounts        Account[]
  sessions        Session[]
  videoStates     UserVideo[]
  channels        Channel[]
  lastSyncAt             DateTime?
  maxTagsPerVideo        Int         @default(8)
  maxVideosPerChannelSync Int        @default(500)
  minVideoDurationSec    Int         @default(300)
  tagExtractionMethod    String      @default("ollama")
  tagBatchMode           String      @default("untagged")
  geminiModel            String      @default("gemini-2.5-flash")
  ollamaMaxChunks        Int         @default(5)
  tagLanguage            String      @default("en")
  selectedCategory       String?
  createdAt              DateTime    @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Channel {
  id                String     @id
  title             String
  thumbnail         String?
  uploadsPlaylistId String?
  subscriberCount   Int?
  videoCount        Int?
  viewCount         Int?
  videos            Video[]
  users             User[]
  categories        Category[]
  lastSyncedAt      DateTime?
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  channels Channel[]
}

model Video {
  id                  String      @id
  title               String
  description         String?
  thumbnail           String?
  durationSec         Int?
  viewCount           Int?
  likeCount           Int?
  commentCount        Int?
  youtubeTags         String?
  publishedAt         DateTime
  channelId           String?
  channel             Channel?    @relation(fields: [channelId], references: [id])
  userStates          UserVideo[]
  transcript          String?
  transcriptFetchedAt DateTime?
  category            String?
  videoTags           VideoTag[]
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  videoTags VideoTag[]
}

model VideoTag {
  id      String @id @default(cuid())
  videoId String
  tagId   String
  score   Float
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([videoId, tagId])
}

model UserVideo {
  id               String   @id @default(cuid())
  userId           String
  videoId          String
  status           String   @default("UNWATCHED")
  progressSec      Int      @default(0)
  addedStandalone  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video            Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}
